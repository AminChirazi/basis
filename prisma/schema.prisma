// Basis schema: the back office core.
//
// v1 ships the operational primitives every back office needs:
// users, organizations, membership, roles, and an audit trail.
// Time tracking and invoicing build on top of these and land in
// later migrations.
//
// Models are grouped by the module that owns them. A single
// Prisma client is generated for the whole deployment; the module
// boundary is enforced in code (each module's service is the only
// thing that touches its tables).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Core: authentication ───────────────────────────────────────
//
// User, Session, Account and Verification are managed by Better
// Auth, the default self-hosted auth provider. To use a different
// provider (Auth0, Clerk, corporate SSO), implement the
// AuthAdapter interface instead; these tables back the default.

model User {
  id            String       @id @default(cuid())
  name          String
  email         String       @unique
  emailVerified Boolean      @default(false)
  image         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  sessions      Session[]
  accounts      Account[]
  memberships   Membership[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

// ── Module: identity ───────────────────────────────────────────

/// An organization. Every piece of back office data is scoped to
/// one, but a deployment serves a single organization: this is
/// internal structure, not multi-tenant isolation.
model Organization {
  id          String       @id @default(cuid())
  /// URL-safe identifier, unique across the deployment.
  slug        String       @unique
  name        String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  memberships Membership[]
  roles       Role[]
  auditEvents AuditEvent[]
  projects    Project[]
  timeEntries TimeEntry[]
  invoices    Invoice[]
  links       Link[]
}

/// Links a user to an organization. Role assignments hang off the
/// membership, so a user can hold different roles in each org.
model Membership {
  id             String           @id @default(cuid())
  userId         String
  organizationId String
  createdAt      DateTime         @default(now())
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  roles          MembershipRole[]
  timeEntries    TimeEntry[]

  @@unique([userId, organizationId])
  @@index([organizationId])
}

// ── Module: rbac ───────────────────────────────────────────────

/// A role within an organization. Roles are database rows, not an
/// enum, so an org can rename or add them without a migration.
/// Code gates look roles up by `key`, never by id or display name.
model Role {
  id             String           @id @default(cuid())
  organizationId String
  /// Stable code-side identifier, e.g. "owner". Unique per org.
  key            String
  name           String
  description    String?
  /// Display order in role pickers. Lower comes first.
  ord            Int              @default(100)
  createdAt      DateTime         @default(now())
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships    MembershipRole[]

  @@unique([organizationId, key])
}

/// Join row: a membership holds a role. A membership may hold
/// several; access checks ask whether ANY held role grants access.
model MembershipRole {
  id           String     @id @default(cuid())
  membershipId String
  roleId       String
  /// User id of whoever granted this role. Null for seed grants.
  /// No foreign key, so removing the granter never erases history.
  assignedById String?
  assignedAt   DateTime   @default(now())
  membership   Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([membershipId, roleId])
}

// ── Module: audit ──────────────────────────────────────────────

/// Append-only record of every state change in an organization.
/// Written inside the same transaction as the change itself, so a
/// self-hosted deployment has a complete, owned audit trail.
model AuditEvent {
  id             String       @id @default(cuid())
  organizationId String
  /// User id of the actor. Null for system actions.
  actorUserId    String?
  /// Verb describing what happened, e.g. "role.assigned".
  action         String
  /// Type and id of the affected entity, when there is one.
  targetType     String?
  targetId       String?
  /// Extra structured context for the event.
  metadata       Json?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
}

// ── Module: timetracking ───────────────────────────────────────

/// Something time is logged against, e.g. a client engagement or
/// an internal initiative. Archived projects stay for reporting
/// but drop out of pickers.
model Project {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  /// Optional short code shown in pickers and reports.
  code           String?
  archived       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  timeEntries    TimeEntry[]

  @@index([organizationId])
}

/// A logged stretch of work. Belongs to the membership that logged
/// it, so "who" is always scoped to the organization.
model TimeEntry {
  id              String       @id @default(cuid())
  organizationId  String
  membershipId    String
  projectId       String?
  description     String
  startedAt       DateTime
  /// Logged duration in minutes.
  durationMinutes Int
  billable        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  membership      Membership   @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  project         Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([organizationId, startedAt])
  @@index([membershipId])
  @@index([projectId])
}

// ── Module: invoicing ──────────────────────────────────────────

/// A bill issued to a client. The total is denormalized from the
/// lines so listing invoices never needs a join.
model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  /// Human-facing invoice number, unique within the organization.
  number         String
  /// "draft" | "sent" | "paid" | "void".
  status         String        @default("draft")
  /// ISO 4217 currency code, e.g. "EUR".
  currency       String
  clientName     String
  clientAddress  String?
  issueDate      DateTime
  dueDate        DateTime?
  notes          String?
  /// Sum of all line amounts, in minor units (e.g. cents).
  totalCents     Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lines          InvoiceLine[]

  @@unique([organizationId, number])
  @@index([organizationId, status])
}

/// One line on an invoice. Amounts are integers in minor units to
/// avoid floating-point rounding.
model InvoiceLine {
  id              String  @id @default(cuid())
  invoiceId       String
  description     String
  /// Whole units (hours, items). Fractional quantities are not
  /// supported in v1.
  quantity        Int
  /// Price per unit in minor units (e.g. cents).
  unitAmountCents Int
  /// quantity * unitAmountCents, stored so totals never drift.
  amountCents     Int
  invoice         Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// ── Core: module links ─────────────────────────────────────────

/// A typed association between records owned by different
/// modules. Lets modules relate data without a foreign key across
/// the module boundary. Each end is identified by a "module:Type"
/// string plus the record id.
model Link {
  id             String       @id @default(cuid())
  organizationId String
  fromType       String
  fromId         String
  toType         String
  toId           String
  /// Relation name, e.g. "billed_on".
  relation       String
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([fromType, fromId, toType, toId, relation])
  @@index([fromType, fromId, relation])
  @@index([toType, toId, relation])
  @@index([organizationId])
}
