# PostgreSQL connection string.
DATABASE_URL="postgresql://user:password@localhost:5432/basis"

# Secret used to sign and verify session JWTs (default auth adapter).
# Generate one with: openssl rand -base64 32
BASIS_AUTH_SECRET="change-me-generate-a-strong-random-value"

# Name of the session cookie set by the default JWT auth adapter.
BASIS_SESSION_COOKIE="basis_session"
