# PostgreSQL connection string.
DATABASE_URL="postgresql://user:password@localhost:5432/basis"

# Better Auth: the default self-hosted authentication.
# Generate the secret with: openssl rand -base64 32
BETTER_AUTH_SECRET="change-me-generate-a-strong-random-value"
BETTER_AUTH_URL="http://localhost:3000"

# Optional. Only needed if you swap the default for the JWT
# external-identity-provider adapter (src/auth/jwt-adapter.ts).
BASIS_AUTH_SECRET="change-me-generate-a-strong-random-value"
BASIS_SESSION_COOKIE="basis_session"
